# Database Configuration
# SQLite is the default (zero-config). Uncomment below to use PostgreSQL instead:



# Model Server Configuration
# Generic endpoints - works with any OpenAI-compatible server

# Embeddings Server (required) - for generating embeddings
# Supports: Ollama (/api/tags), LM Studio (/models), or any OpenAI-compatible API
#EMBEDDING_ENDPOINT=http://127.0.0.1:11434
#EMBEDDING_MODEL=nomic-embed-text

# LLM Server (optional) - for code generation
# Supports: LM Studio (/models), Ollama (/api/tags), or any OpenAI-compatible API
LLM_ENDPOINT=http://127.0.0.1:1234/v1
# Tier 1 (fast/cheap) — set via GUI or here as fallback
#SMALL_MODEL_ONE=glm-4.7

# Tier 2 (complex/quality) — set via GUI or here as fallback
#TIER2_MODEL_ONE=glm-4.7

# Server Configuration
# Canonical port block: 4710-4716 (vacant range outside Windows excluded ports).
# Defaults live in config/port-defaults.json; these env vars override at runtime.
API_PORT=4710
ORCHESTRATOR_PORT=4711
GUI_PORT=4712
PARTITION_SERVER_PORT=4713
HOST=localhost
HEARTBEAT_INTERVAL=10000

# Built-in Labs (orchestrator-managed)
# The orchestrator can spawn the labs in podbit-labs as managed services. Each
# lab is auto-detected if its directory exists at PODBIT_LABS_ROOT (default
# `../podbit-labs`). Set the per-lab AUTOSTART flag to true if you want the
# orchestrator to start it on boot. Labs without the flag still appear in the
# Services page and can be started manually.
# PODBIT_LABS_ROOT=../podbit-labs   # uncomment to override the default
LAB_MATH_AUTOSTART=true
LAB_NN_AUTOSTART=true
LAB_CRITIQUE_AUTOSTART=true

# EVM_PYTHON_PATH is written automatically by scripts/setup-python.ts when you
# create the lab Python venv. Leave commented to fall back to the system
# python / python3 on PATH.
# EVM_PYTHON_PATH=./data/evm-venv/Scripts/python.exe
