{
  "name": "podbit",
  "version": "0.6.2",
  "description": "data synthesis engine for LLMs — knowledge graph, and research augmentation",
  "type": "module",
  "main": "server.ts",
  "scripts": {
    "start": "tsx server.ts",
    "dev": "tsx server.ts",
    "orchestrate": "tsx orchestrator.ts",
    "mcp": "tsx mcp-stdio.ts",
    "mcp:remote": "tsx mcp-stdio-remote.ts",
    "seeds": "tsx seeds.ts",
    "seeds:load": "tsx seeds.ts load",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:mcp": "node tests/mcp-integration-tests.js",
    "test:llm": "node tests/llm-agnostic-tests.js",
    "pool": "tsx partition-server.ts",
    "build:site-docs": "tsx --tsconfig site/tsconfig.json site/build-docs.ts",
    "generate-cert": "tsx scripts/generate-cert.ts",
    "setup": "tsx scripts/setup.ts",
    "setup:local": "tsx scripts/setup.ts local",
    "setup:remote": "tsx scripts/setup.ts remote",
    "setup:client": "tsx scripts/setup-client.ts",
    "setup:python": "tsx scripts/setup-python.ts"
  },
  "keywords": [
    "ai",
    "llm",
    "knowledge-graph",
    "data-synthesis",
    "mcp",
    "automated-research"
  ],
  "author": "Rob McGlade",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@dicebear/collection": "^9.3.1",
    "@dicebear/core": "^9.3.1",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^5.0.0",
    "compromise": "^14.14.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mammoth": "^1.11.0",
    "node-stream-zip": "^1.15.0",
    "pdf-parse": "^2.4.5",
    "sharp": "^0.34.5",
    "undici": "^8.0.2",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@jest/globals": "^29.7.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.1.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "jest": "^29.7.0",
    "lucide-react": "^0.294.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "better-sqlite3-multiple-ciphers": "^12.6.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
