{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["jest", "node"],
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "allowJs": true
  },
  "include": [
    "tests/**/*.ts",
    "*.ts",
    "core/**/*.ts",
    "db/**/*.ts",
    "handlers/**/*.ts",
    "routes/**/*.ts",
    "mcp/**/*.ts",
    "proxy/**/*.ts",
    "models/**/*.ts",
    "services/**/*.ts",
    "evm/**/*.ts",
    "kb/**/*.ts",
    "config/**/*.ts",
    "config-sections/**/*.ts",
    "context/**/*.ts",
    "utils/**/*.ts",
    "vector/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "gui", "data"]
}
